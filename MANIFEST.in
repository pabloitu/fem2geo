include README.md
include requirements.txt
include requirements_dev.txt
include environment.yml
include pyproject.toml
include LICENSE

graft fem2geo
graft tests
prune docs/_build
prune docs/reference/generated
prune examples

global-exclude .git*
global-exclude *.pyc
global-exclude *.html
global-exclude *.so
global-exclude *~
global-exclude .DS_Store
